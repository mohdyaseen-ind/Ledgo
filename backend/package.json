        "build": "npm i && prisma generate && tsc"
    },
    "dependencies": {
        "@prisma/client": "^5.7.1",
        "bcrypt": "^6.0.0",
        "cookie-parser": "^1.4.7",
        "cors": "^2.8.5",
        "dotenv": "^17.2.3",
        "express": "^4.18.2",
        "jsonwebtoken": "^9.0.2",
        "xlsx": "^0.18.5"
    },
    "devDependencies": {
        "@types/bcrypt": "^6.0.0",
        "@types/cookie-parser": "^1.4.10",
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/node": "^20.10.6",
        "@types/xlsx": "^0.0.35",
        "nodemon": "^3.0.2",
        "prisma": "^5.7.1",
        "ts-node": "^10.9.2",
        "typescript": "^5.3.3"
